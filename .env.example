# ── LLM (any provider via litellm) ──────────────────────────────────────────
# Model string follows the litellm format: "<provider>/<model>".
# Examples:
#   anthropic/claude-sonnet-4-6
#   openai/gpt-4o
#   groq/llama-3.3-70b-versatile
#   gemini/gemini-2.0-flash
#   mistral/mistral-large-latest
LLM_MODEL=anthropic/claude-sonnet-4-6
# If set, overrides provider env vars (ANTHROPIC_API_KEY etc.) for the main LLM.
LLM_API_KEY=your_anthropic_api_key_here

# Anthropic backward compat — if you prefer to set ANTHROPIC_API_KEY directly,
# you can leave LLM_API_KEY empty and litellm will pick this up for anthropic/* models.
ANTHROPIC_API_KEY=

# ── OpenAI (TTS for podcast / newsletter audio) ─────────────────────────────
# Get from: https://platform.openai.com/api-keys
# Optional — if unset, podcast / newsletter audio falls back to free gTTS.
OPENAI_API_KEY=your_openai_api_key_here
# OpenAI TTS voice: alloy, echo, fable, onyx, nova, shimmer
PODCAST_VOICE=alloy

# ── Twitter / X ─────────────────────────────────────────────────────────────
# Get from: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
TWITTER_ENABLED=true

# ── Reddit ──────────────────────────────────────────────────────────────────
# Create a "script" app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USERNAME=your_reddit_username_here
REDDIT_ENABLED=true

# ── GitHub ──────────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/tokens (no scopes needed for public data)
GITHUB_TOKEN=your_github_token_here
GITHUB_ENABLED=true

# ── Google / Gemini ──────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey (free tier available)
# Used when ANALYSIS_MODEL=gemini/... — leave empty to use ANALYSIS_API_KEY instead
GEMINI_API_KEY=your_gemini_api_key_here

# ── YouTube ─────────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/ → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_ENABLED=true
# Comma-separated channel IDs (defaults are set in config.py if left empty)
YOUTUBE_CHANNEL_IDS=

# ── LinkedIn ─────────────────────────────────────────────────────────────────
# LinkedIn uses RSS feeds — no API key required
LINKEDIN_ENABLED=true

# ── Pipeline ────────────────────────────────────────────────────────────────
DEDUP_STRATEGY=semantic
DEDUP_SIMILARITY_THRESHOLD=0.82
BATCH_SIZE=15
MAX_ITEMS_PER_SOURCE=1000

# ── Search ──────────────────────────────────────────────────────────────────
# Hybrid BM25/semantic blend for search (0..1). 1.0 = pure BM25 (keyword,
# tickers), 0.0 = pure semantic (paraphrase), 0.5 = legacy balanced RRF.
# Override per-request with /api/panel?alpha=0.8 .
DEFAULT_HYBRID_ALPHA=0.5
TICKER_ALPHA=0.75
# Per-list cap on BM25 / semantic rank lists before RRF fusion. Keeps the
# fused ranking balanced regardless of upstream list sizes. 200 comfortably
# exceeds the default semantic top_k (limit*3) with headroom.
SEARCH_RRF_TOP_K=200
# Faster/cheaper model for bulk scoring (relevance/tags/sentiment).
ANALYSIS_MODEL=gemini/gemini-2.5-flash
# API key for the analysis model (set when using a different provider than the main LLM)
ANALYSIS_API_KEY=your_gemini_api_key_here
# Multi-model rotation: batches are distributed round-robin across these models.
# Useful when each model/key has its own RPM quota (e.g. two Gemini free-tier keys).
# Comma-separated, ANALYSIS_API_KEYS entries correspond 1:1 with ANALYSIS_MODELS.
# Example: ANALYSIS_MODELS=gemini/gemini-2.5-flash,gemini/gemini-2.5-flash
#          ANALYSIS_API_KEYS=key_account1,key_account2
ANALYSIS_MODELS=
ANALYSIS_API_KEYS=
# RPM limit per model in ANALYSIS_MODELS (parallel list). Controls weighted batch
# distribution — faster models receive proportionally more batches. Also enforces
# a per-model rate-limiting lock so no model exceeds its RPM cap.
# Example: ANALYSIS_RPMS=10,50 → model_B gets 5× more batches than model_A
ANALYSIS_RPMS=
# Max concurrent LLM calls during batch analysis (set to number of models for best throughput)
ANALYSIS_CONCURRENCY=1

# ── Storage ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///data/news.db
RETENTION_DAYS=30

# ── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULE_INTERVAL_HOURS=4
# IANA timezone used for cron jobs (digest, newsletter, prune). Examples:
#   America/Los_Angeles (PST/PDT), America/New_York, Europe/London, Asia/Shanghai
SCHEDULER_TIMEZONE=America/Los_Angeles

# ── Newsletter (daily email) ─────────────────────────────────────────────────
# Sends a daily email (HTML summary + article list + MP3 audio) for your
# default topics. Topics come from the UI's "Default Topics" gear icon unless
# overridden by NEWSLETTER_TOPICS below.
NEWSLETTER_ENABLED=false
NEWSLETTER_EMAIL_TO=you@example.com
NEWSLETTER_EMAIL_FROM=
NEWSLETTER_HOUR=7
NEWSLETTER_MINUTE=0
NEWSLETTER_HOURS_LOOKBACK=24
NEWSLETTER_INCLUDE_AUDIO=true
# Leave empty to use whatever you saved in the UI's Default Topics panel
NEWSLETTER_TOPICS=

# Public URL where this app is reachable.  REQUIRED for inline audio
# playback in the email — the newsletter embeds
#   {PUBLIC_BASE_URL}/newsletter/audio/<topic>-briefing-<date>.mp3
# which Gmail/Outlook open in a browser tab (streaming) instead of
# forcing a download of the attachment.  Leave empty to only rely on
# the MP3 attachment (Gmail will still offer "download" for it).
# Example: PUBLIC_BASE_URL=https://news.yourdomain.com
PUBLIC_BASE_URL=
# Directory where briefing MP3s are persisted so the web app can stream
# them.  Relative to the project root.
NEWSLETTER_AUDIO_DIR=data/newsletter_audio
# Whether to also attach the MP3 to the email.  Safe default = true so
# users get audio even when they open the message offline.  Set to false
# once PUBLIC_BASE_URL is working, to keep emails small.
NEWSLETTER_ATTACH_AUDIO=true

# ── SMTP (required for newsletter) ───────────────────────────────────────────
# Gmail: create an App Password at https://myaccount.google.com/apppasswords
# (2-Step Verification must be enabled on your account). Use the 16-char
# app password here — NOT your regular Gmail login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_USE_TLS=true
