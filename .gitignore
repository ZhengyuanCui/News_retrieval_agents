# ── Runtime data (DB, embeddings, generated audio, exports) ─────────────────
# Everything under data/ is produced at runtime and specific to one install.
# Keep the directory present in git with a .gitkeep if you need it to exist
# on fresh clones; otherwise the app creates it on first run.
data/

# Stray audio files elsewhere in the tree (briefings, podcasts, TTS tests)
*.mp3
*.m4a
*.wav
*.ogg

